#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_PATH="${SCRIPT_DIR}/io_sim_config.json"

if [[ $# -ne 0 ]]; then
  echo "ERROR: This script does not take arguments. It always uses: ${CONFIG_PATH}" >&2
  exit 2
fi

if [[ ! -f "${CONFIG_PATH}" ]]; then
  echo "ERROR: config not found: ${CONFIG_PATH}" >&2
  exit 2
fi

read_config_var() {
  local key="$1"
  python3 - "$CONFIG_PATH" "$key" <<'PY'
import json, sys
path, key = sys.argv[1], sys.argv[2]
cfg = json.load(open(path, "r", encoding="utf-8"))
cur = cfg
for part in key.split("."):
    if part not in cur:
        print("")
        sys.exit(0)
    cur = cur[part]
if isinstance(cur, bool):
    print("true" if cur else "false")
elif isinstance(cur, (dict, list)):
    print(json.dumps(cur))
else:
    print(cur)
PY
}

SCONS_JOBS="$(read_config_var scons_jobs)"
GEM5_DIR_REL="$(read_config_var gem5_dir)"
BUILD_TARGET_REL="$(read_config_var build_target)"
PROTOCOL="$(read_config_var protocol)"

[[ -z "${SCONS_JOBS}" ]] && SCONS_JOBS="4"
[[ -z "${GEM5_DIR_REL}" ]] && GEM5_DIR_REL="gem5"
[[ -z "${BUILD_TARGET_REL}" ]] && BUILD_TARGET_REL="build/NULL/gem5.opt"
[[ -z "${PROTOCOL}" ]] && PROTOCOL="Garnet_standalone"

GEM5_DIR="${SCRIPT_DIR}/${GEM5_DIR_REL}"

if [[ ! -f "${GEM5_DIR}/SConstruct" ]]; then
  echo "ERROR: gem5 repo not found at: ${GEM5_DIR}" >&2
  echo "Hint: initialize the submodule under io_sim/ first." >&2
  exit 2
fi

echo "[build_io_sim] Installing Python dependencies via pip (gem5 requirements.txt)..."
python -m pip install -U pip
python -m pip install -r "${GEM5_DIR}/requirements.txt"

echo "[build_io_sim] Building gem5 target '${BUILD_TARGET_REL}' with PROTOCOL='${PROTOCOL}' (-j ${SCONS_JOBS})..."
cd "${GEM5_DIR}"
scons --ignore-style "${BUILD_TARGET_REL}" "PROTOCOL=${PROTOCOL}" "-j${SCONS_JOBS}"

echo "[build_io_sim] Done."
echo "[build_io_sim] Built binary: ${GEM5_DIR}/${BUILD_TARGET_REL}"
